# Knowledge Governance Layer environment sample
# Copy to .env for local development. Do not commit real secrets.

# Azure OpenAI: chat model deployment for the serving agent.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-chat-api-key>
AZURE_OPENAI_CHAT_DEPLOYMENT=<your-chat-deployment-name>
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure OpenAI: embedding deployment for governed knowledge search.
AZURE_OPENAI_ENDPOINT_EMBEDDING=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY_EMBEDDING=<your-embedding-api-key>
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Governed Knowledge API.
GOVERNED_API_BASE=http://127.0.0.1:8000

# Optional override. Defaults to data/approved_knowledge.json.
APPROVED_KNOWLEDGE_PATH=data/approved_knowledge.json

# --- Optional: read approved_knowledge from Azure Blob Storage instead of a local file ---
# If APPROVED_KNOWLEDGE_BLOB_CONTAINER is set together with a connection string
# (or account URL), the serving layer reads the JSON from Blob and picks up
# changes WITHOUT redeploying. Leave unset to use the local file above.
# APPROVED_KNOWLEDGE_BLOB_CONTAINER=approved-knowledge
# APPROVED_KNOWLEDGE_BLOB_NAME=approved_knowledge.json
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# Alternatively, use managed identity (no secret) by setting the account URL:
# AZURE_STORAGE_ACCOUNT_URL=https://<youraccount>.blob.core.windows.net

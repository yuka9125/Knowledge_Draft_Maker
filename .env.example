# Knowledge Governance Layer environment sample.
# Copy to .env for local development. Do not commit real secrets.

AZURE_OPENAI_ENDPOINT=https://kgl-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
PORT=8000

# Optional local override. Defaults to data/approved_knowledge.json.
APPROVED_KNOWLEDGE_PATH=data/approved_knowledge.json

# Optional when the Semantic Kernel plugin calls a separate API process.
GOVERNED_API_BASE=http://127.0.0.1:8000
